# RateRadar web — environment variables
# Copy this file to .env.local for local development.
# Production values are set in Vercel project settings.

# Supabase (public — anon/publishable key, safe to expose in the client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Google AdSense publisher ID (public — appears in the page HTML).
# Format: ca-pub-XXXXXXXXXXXXXXXX
# Without this env var the AdSense script tag is not rendered.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
