# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # pipeline only, never commit

# Web
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Data pipeline
POSTHOG_API_KEY=
SENTRY_DSN_PIPELINE=

# Fallback data sources (optional)
FRED_API_KEY=

# Alerts (when probability deltas exceed threshold)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.lawoflarge.rateradar
APNS_PRIVATE_KEY_PATH=./secrets/apns.p8
